## Server
PORT=5000

## Database (optional for dev; app falls back to in-memory jobs)
# DATABASE_URL=postgresql://recruit_guard:recruit_guard_password@localhost:5432/recruit_guard

## LLM providers
## Grok (xAI) - required for analysis, job suggestions, and interview prep if Gemini/Groq are not set
GROK_API_KEY=your_grok_api_key

## Groq (OpenAI-compatible) - used for fast classification and extraction
# GROQ_API_KEY=your_groq_api_key

## Gemini (Google AI) - used for reasoning and explanations
# GEMINI_API_KEY=your_gemini_api_key
## Gemini model (optional)
# GEMINI_MODEL=gemini-2.0-flash

## Session (optional; default used in dev)
# SESSION_SECRET=your-secret-for-cookies
